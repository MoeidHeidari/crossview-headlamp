  "keywords": [
    "crossview",
    "headlamp",
    "headlamp-plugin",
    "kubernetes",
    "plugin",
    "platform-engineering",
    "crossplane",
    "kubernetes-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
